{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "Custom regex managers for tool versions hardcoded in workflow YAML. Renovate complements Dependabot here: Dependabot keeps handling gomod/npm/docker/github-actions; this config only enables the custom.regex manager.",
  "extends": [
    "config:base",
    ":semanticCommits",
    ":dependencyDashboard"
  ],
  "labels": ["deps", "deps:renovate"],
  "schedule": ["before 06:00 on monday"],
  "timezone": "Europe/Paris",
  "enabledManagers": ["custom.regex"],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["^\\.github/workflows/.+\\.ya?ml$"],
      "matchStrings": [
        "uses: golangci/golangci-lint-action@[a-f0-9]+\\s+# v[\\d.]+\\s*\\n\\s*with:\\s*\\n(?:\\s*[^\\n]*\\n)*?\\s*version: (?<currentValue>v\\d+\\.\\d+\\.\\d+)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "golangci/golangci-lint",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "fileMatch": ["^\\.github/workflows/.+\\.ya?ml$"],
      "matchStrings": [
        "zricethezav/gitleaks:(?<currentValue>v\\d+\\.\\d+\\.\\d+)"
      ],
      "datasourceTemplate": "docker",
      "depNameTemplate": "zricethezav/gitleaks",
      "versioningTemplate": "semver"
    }
  ],
  "packageRules": [
    {
      "matchManagers": ["custom.regex"],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": false,
      "prCreation": "immediate"
    }
  ]
}
